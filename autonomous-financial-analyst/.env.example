# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── NewsAPI ───────────────────────────────────────────────────────────────────
NEWS_API_KEY=your-newsapi-key-here

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Comma-separated allowed CORS origins — set to your frontend URL in production
ALLOWED_ORIGINS=http://localhost:8501
# Optional API key guard — set any secret string; all requests must include X-API-Key header
API_SECRET_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/financial_analyst.db

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0

# ── LLM Model ─────────────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── FinBERT ───────────────────────────────────────────────────────────────────
FINBERT_MODEL=ProsusAI/finbert

# ── Market Data ───────────────────────────────────────────────────────────────
MARKET_DATA_CACHE_TTL=300
STOCK_UNIVERSE=AAPL,MSFT,NVDA,TSLA,AMZN,META,GOOGL,AMD,NFLX,INTC

# ── RAG ───────────────────────────────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
RAG_TOP_K=5
