# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Data (SQLite DB + FAISS index — machine-local, not version-controlled) ────
data/*.db
data/*.idx
data/*.meta
# Keep the directory itself tracked
!data/.gitkeep

